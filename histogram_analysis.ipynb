      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "data = np.random.normal(0,1,1000)\n",
        "plt.hist(data,bins=30)\n",
        "plt.title(\"histogram of normal distribution\")\n",
        "plt.xlabel(\"values\")\n",
        "plt.ylabel(\"frequency\")\n",
        "plt.show()"
      ]
